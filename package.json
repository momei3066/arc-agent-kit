{
  "name": "arc-agent-kit",
  "version": "0.1.0",
  "description": "A TypeScript toolkit that lets LLM agents transact on Arc Network — Circle's stablecoin-native L1. Ships a viem-based SDK, an MCP server, a CLI, and Anthropic / OpenAI function-call schemas.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "bin": {
    "arc": "dist/bin/arc.js",
    "arc-mcp": "dist/bin/arc-mcp.js",
    "arc-gen-wallet": "dist/bin/gen-wallet.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "cli": "tsx bin/arc.ts",
    "mcp": "tsx bin/arc-mcp.ts",
    "gen-wallet": "tsx bin/gen-wallet.ts",
    "example:balance": "tsx examples/check-balance.ts",
    "example:send-usdc": "tsx examples/send-usdc.ts",
    "example:send-eurc": "tsx examples/send-eurc.ts",
    "example:agent": "tsx examples/claude-agent.ts",
    "example:simulate": "tsx examples/simulate-send.ts",
    "example:x402": "tsx examples/x402-pay.ts",
    "example:subs": "tsx examples/subscription-demo.ts",
    "deploy:subscriptions": "tsx scripts/deploy-subscriptions.ts"
  },
  "keywords": [
    "arc-network",
    "arc",
    "circle",
    "usdc",
    "eurc",
    "stablecoins",
    "ai-agent",
    "llm",
    "mcp",
    "model-context-protocol",
    "function-calling",
    "viem",
    "web3",
    "cctp",
    "x402",
    "http-402",
    "paid-api"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@x402/evm": "^2.12.0",
    "@x402/fetch": "^2.12.0",
    "dotenv": "^16.4.5",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "solc": "^0.8.35",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
