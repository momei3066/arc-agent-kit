# Copy this file to `.env` and fill in your values.
# NEVER commit a real .env — `.gitignore` already excludes it.
#
# Quick start:
#   npm run gen-wallet            # generates a fresh key into this file
#   open https://faucet.circle.com   # fund the printed address

# Required for any signing operation (send-* commands and tools).
# Generate a FRESH wallet for testnet only — do not reuse a mainnet key.
ARC_PRIVATE_KEY=0x

# Optional. Defaults to the public testnet RPC.
# Alternatives:
#   https://rpc.blockdaemon.testnet.arc.network
#   https://rpc.drpc.testnet.arc.network
#   https://rpc.quicknode.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network

# Required only for the Claude agent example (examples/claude-agent.ts).
ANTHROPIC_API_KEY=
